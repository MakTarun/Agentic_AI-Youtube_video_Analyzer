def _build_styles(accent: colors.Color = BRAND_ACCENT) -> dict:
    base = getSampleStyleSheet()
    return {
        "title": ParagraphStyle(
            "ReportTitle",
            parent=base["Normal"],
            fontName="Helvetica-Bold",
            fontSize=20,
            leading=26,
            textColor=colors.white,
            alignment=TA_CENTER,
            spaceAfter=2,
        ),
        "subtitle": ParagraphStyle(
            "Subtitle",
            parent=base["Normal"],
            fontName="Helvetica-Oblique",
            fontSize=10,
            textColor=colors.HexColor("#CCCCDD"),
            alignment=TA_CENTER,
        ),
        "section": ParagraphStyle(
            "Section",
            parent=base["Normal"],
            fontName="Helvetica-Bold",
            fontSize=12,
            leading=16,
            textColor=accent,
            spaceBefore=12,
            spaceAfter=4,
        ),
        "body": ParagraphStyle(
            "Body",
            parent=base["Normal"],
            fontName="Helvetica",
            fontSize=10.5,
            leading=16,
            textColor=BODY_GREY,
            alignment=TA_JUSTIFY,
            spaceAfter=4,
        ),
        "bullet": ParagraphStyle(
            "Bullet",
            parent=base["Normal"],
            fontName="Helvetica",
            fontSize=10.5,
            leading=16,
            textColor=BODY_GREY,
            leftIndent=12,
            spaceAfter=4,
        ),
        "footer": ParagraphStyle(
            "Footer",
            parent=base["Normal"],
            fontName="Helvetica-Oblique",
            fontSize=8,
            textColor=colors.grey,
            alignment=TA_CENTER,
        ),
    }


def _header_banner(story: list, title: str, subtitle: str,
                   bg: colors.Color = BRAND_DARK) -> None:
    """Render a full-width coloured banner with title + subtitle."""
    st = _build_styles()
    content = [Paragraph(title, st["title"]),
               Paragraph(subtitle, st["subtitle"])]
    tbl = Table([[content]], colWidths=["100%"])
    tbl.setStyle(TableStyle([
        ("BACKGROUND",   (0, 0), (-1, -1), bg),
        ("TOPPADDING",   (0, 0), (-1, -1), 18),
        ("BOTTOMPADDING",(0, 0), (-1, -1), 18),
        ("LEFTPADDING",  (0, 0), (-1, -1), 20),
        ("RIGHTPADDING", (0, 0), (-1, -1), 20),
    ]))
    story.append(tbl)
    story.append(Spacer(1, 0.3 * cm))
    story.append(HRFlowable(width="100%", thickness=2,
                             color=RULE_COLOUR, spaceAfter=10))


def _rule(story: list) -> None:
    story.append(HRFlowable(width="100%", thickness=0.5,
                             color=colors.HexColor("#DDDDEE"), spaceAfter=6))


def _add_numbered_questions(story: list, questions: list, styles: dict) -> None:
    if not questions:
        return
    story.append(Paragraph("Key Questions", styles["section"]))
    _rule(story)
    for i, q in enumerate(questions, 1):
        story.append(Paragraph(f"<b>Q{i}.</b>  {q}", styles["bullet"]))
    story.append(Spacer(1, 6))


def _add_bullets(story: list, items: list, styles: dict) -> None:
    for item in items:
        story.append(Paragraph(f"• {item}", styles["bullet"]))
    story.append(Spacer(1, 6))


def generate_pdf(text: str, domain: str = "General Knowledge") -> bytes:
    """
    Convert summary text to a polished PDF.

    Args:
        text:   The summary / analysis text from Claude.
        domain: One of Finance | Tech | Sports | Gaming | Questions |
                General Knowledge — controls colours and title.

    Returns:
        Raw PDF bytes (pass directly to st.download_button).
    """
    buf     = BytesIO()
    accent  = DOMAIN_COLOURS.get(domain, BRAND_DARK)
    title   = DOMAIN_ICONS.get(domain, "📝 Video Summary Report")
    styles  = _build_styles(accent)

    doc = SimpleDocTemplate(
        buf,
        pagesize=A4,
        leftMargin=2 * cm, rightMargin=2 * cm,
        topMargin=1.8 * cm, bottomMargin=2 * cm,
        title=title,
    )

    story = []

    # ── Banner ────────────────────────────────────────────────────────────────
    _header_banner(story, title, "Auto-generated from YouTube transcript",
                   bg=DOMAIN_COLOURS.get(domain, BRAND_DARK))

    # ── Parse & render body ───────────────────────────────────────────────────
    lines        = [l.strip() for l in text.split("\n")]
    numbered_qs  = []   # collect numbered items before flushing

    def flush_qs():
        nonlocal numbered_qs
        if numbered_qs:
            _add_numbered_questions(story, numbered_qs, styles)
            numbered_qs = []

    for line in lines:
        if not line:
            continue

        # Strip markdown bold
        line = line.replace("**", "")

        # Numbered item  →  "1. Some text" or "1) Some text"
        m = re.match(r"^(\d+)[.)]\s+(.+)$", line)
        if m:
            numbered_qs.append(m.group(2))
            continue

        # Bullet / dash line
        if line.startswith(("•", "-", "*")):
            flush_qs()
            clean = line.lstrip("•-* ").strip()
            story.append(Paragraph(f"• {clean}", styles["bullet"]))
            continue

        # Short title-like line → section heading
        if len(line) < 75 and (line.isupper() or line.istitle()):
            flush_qs()
            story.append(Paragraph(line, styles["section"]))
            _rule(story)
            continue

        # Normal body paragraph
        flush_qs()
        story.append(Paragraph(line, styles["body"]))
        story.append(Spacer(1, 2))

    flush_qs()  # flush any trailing numbered items

    # ── Footer ────────────────────────────────────────────────────────────────
    story.append(Spacer(1, 0.5 * cm))
    story.append(HRFlowable(width="100%", thickness=1,
                             color=RULE_COLOUR, spaceAfter=6))
    story.append(Paragraph(
        "Generated automatically · YouTube Video Summarizer", styles["footer"]
    ))

    doc.build(story)
    return buf.getvalue()


